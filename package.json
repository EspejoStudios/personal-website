{
  "name": "personal-website",
  "version": "1.0.0",
  "description": "Espejo Studios personal website",
  "scripts": {
    "sass:watch": "sass assets/scss/main.scss:assets/css/main.css assets/scss/ivyan.scss:assets/css/ivyan.css --watch --source-map",
    "sass:build": "sass assets/scss/main.scss:assets/css/main.css assets/scss/ivyan.scss:assets/css/ivyan.css --style=compressed --no-source-map",
    "dev": "npm-run-all --parallel sass:watch serve",
    "serve": "live-server --port=3000 --open=index.html"
  },
  "devDependencies": {
    "bootstrap": "^5.3.3",
    "live-server": "^1.2.2",
    "npm-run-all": "^4.1.5",
    "sass": "^1.77.0"
  }
}
